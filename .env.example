# ============================================================
# wz-api — variaveis de ambiente
# Copie para .env e preencha os valores. Nunca commitar .env.
# ============================================================

# ─── Salesforce OAuth 2.0 ─────────────────────────────────────
# Connected App em PRODUCAO (cometa.my.salesforce.com)
SF_CLIENT_ID=3MVG9cHH2bfKACZby2CWjAoqzBlNUyD55Rc3.l7X8QSYV.WCmZl7YjovY2v2ZNIYjXQDHk2l9NDQtvzCJoZHl
SF_CLIENT_SECRET=
# Producao: cometa.my.salesforce.com (My Domain) ou login.salesforce.com
# Sandbox: test.salesforce.com
SF_LOGIN_URL=https://cometa.my.salesforce.com
SF_API_VERSION=v59.0

# ─── NextAuth ─────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=GERE_NO_SERVIDOR_COM_openssl_rand_base64_32
NEXTAUTH_URL=https://wz-api.grupocometa.com.br

# ─── API Security ────────────────────────────────────────────
# Token compartilhado com a extensao (config.js da wz-salesforce).
# Gere com: openssl rand -hex 32
# IMPORTANTE: o mesmo valor precisa estar no config.js da extensao.
API_BEARER_TOKEN=GERE_NO_SERVIDOR_COM_openssl_rand_hex_32

# ─── CORS ────────────────────────────────────────────────────
# Origens permitidas (separadas por virgula). O extension ID fixo e:
#   pkmojofnhnmddfpokdgeihencmjggamj
ALLOWED_ORIGINS=chrome-extension://pkmojofnhnmddfpokdgeihencmjggamj

# ─── Caddy / dominio (usado pelo docker-compose.prod.yml) ────
DOMAIN=wz-api.grupocometa.com.br
ACME_EMAIL=infra@grupocometa.com.br
