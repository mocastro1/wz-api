# ─── Salesforce OAuth 2.0 ─────────────────────────────────────
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://test.salesforce.com
SF_API_VERSION=v59.0

# ─── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET=gere-uma-chave-secreta-aqui
NEXTAUTH_URL=http://localhost:3000

# ─── API Security ────────────────────────────────────────────
# Token compartilhado com a extensao (config.js). Gere com:
#   openssl rand -hex 32
API_BEARER_TOKEN=token-secreto-para-extensao

# ─── CORS ────────────────────────────────────────────────────
# Origens permitidas (separadas por virgula). Inclua a URL do extension ID
# fixo e os dominios de producao. Para a extensao com ID fixo:
#   chrome-extension://pkmojofnhnmddfpokdgeihencmjggamj
ALLOWED_ORIGINS=chrome-extension://pkmojofnhnmddfpokdgeihencmjggamj
